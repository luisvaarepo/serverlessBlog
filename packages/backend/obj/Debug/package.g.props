<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <PackageJsonName Condition="$(PackageJsonName) == ''">@serverless-blog/backend</PackageJsonName>
    <PackageJsonPrivate Condition="$(PackageJsonPrivate) == ''">true</PackageJsonPrivate>
    <PackageJsonVersion Condition="$(PackageJsonVersion) == ''">1.0.0</PackageJsonVersion>
    <PackageJsonScriptsBuild Condition="$(PackageJsonScriptsBuild) == ''">tsc -p tsconfig.json</PackageJsonScriptsBuild>
    <PackageJsonScriptsTest Condition="$(PackageJsonScriptsTest) == ''">vitest run</PackageJsonScriptsTest>
    <PackageJsonDependenciesAwsSdkClientDynamodb Condition="$(PackageJsonDependenciesAwsSdkClientDynamodb) == ''">^3.835.0</PackageJsonDependenciesAwsSdkClientDynamodb>
    <PackageJsonDependenciesAwsSdkLibDynamodb Condition="$(PackageJsonDependenciesAwsSdkLibDynamodb) == ''">^3.835.0</PackageJsonDependenciesAwsSdkLibDynamodb>
    <PackageJsonDependenciesLangchainCore Condition="$(PackageJsonDependenciesLangchainCore) == ''">^0.3.46</PackageJsonDependenciesLangchainCore>
    <PackageJsonDependenciesLangchainGoogleGenai Condition="$(PackageJsonDependenciesLangchainGoogleGenai) == ''">^0.2.15</PackageJsonDependenciesLangchainGoogleGenai>
    <PackageJsonDevdependenciesTypesNode Condition="$(PackageJsonDevdependenciesTypesNode) == ''">^22.7.5</PackageJsonDevdependenciesTypesNode>
    <PackageJsonDevdependenciesTypescript Condition="$(PackageJsonDevdependenciesTypescript) == ''">^5.6.3</PackageJsonDevdependenciesTypescript>
    <PackageJsonDevdependenciesVitest Condition="$(PackageJsonDevdependenciesVitest) == ''">^2.1.9</PackageJsonDevdependenciesVitest>
  </PropertyGroup>
</Project>