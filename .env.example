# Frontend
# Frontend API base URL. Use your deployed API URL (no trailing slash).
# For local backend testing via the Vite proxy, use: /api
VITE_API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod

# AWS CDK deployment target account id (12 digits)
CDK_DEFAULT_ACCOUNT=123456789012
# AWS CDK deployment target region
CDK_DEFAULT_REGION=us-east-1

# Secret used by backend to sign auth tokens
AUTH_SECRET=replace-with-a-strong-random-secret

# Internal premium AI key used by backend-only LangChain generation (not exposed to clients)
INTERNAL_AI_API_KEY=
# Internal You.com search API key used by backend research step (not exposed to clients)
YOU_COM_SEARCH_API_KEY=
# Research mode for You.com premium research requests (use standard to reduce cost)
YOU_COM_RESEARCH_MODE=standard
# Optional override for premium AI model
PREMIUM_AI_MODEL=gemini-2.5-flash
# Temporary system prompt placeholder for premium AI mode
PREMIUM_AI_SYSTEM_PROMPT=
